delta_df["delta_spearman_vs_baseline"] = delta_df["mean_spearman"] - delta_df["baseline_mean_spearman"]
delta_df["delta_pearson_vs_baseline"] = delta_df["mean_pearson"] - delta_df["baseline_mean_pearson"]
delta_df["delta_mse_vs_baseline"] = delta_df["mean_mse"] - delta_df["baseline_mean_mse"]

