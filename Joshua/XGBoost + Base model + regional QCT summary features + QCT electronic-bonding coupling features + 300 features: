        "mean_qct_coupling_features_selected": float(fold_df["n_qct_coupling_features_selected"].mean()),
    }

    print("\nSummary:")
    print(f"Mean R2:       {summary['mean_r2']:.4f} ± {summary['std_r2']:.4f}")
    print(f"Mean Spearman: {summary['mean_spearman']:.4f} ± {summary['std_spearman']:.4f}")
    print(f"Mean Pearson:  {summary['mean_pearson']:.4f} ± {summary['std_pearson']:.4f}")
    print(f"Mean MSE:      {summary['mean_mse']:.4f} ± {summary['std_mse']:.4f}")
    print(f"Mean engineered features selected: {summary['mean_engineered_features_selected']:.2f}")
    print(f"Mean regional QCT features selected: {summary['mean_regional_qct_features_selected']:.2f}")
    print(f"Mean QCT coupling features selected: {summary['mean_qct_coupling_features_selected']:.2f}")

    return summary, fold_df, engineered_feature_counter, regional_feature_counter, coupling_feature_counter


