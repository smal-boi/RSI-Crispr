feature_names = X_df.columns.to_numpy()
X = X_df.to_numpy(dtype=np.float32)

valid_y_mask = ~np.isnan(y)
if valid_y_mask.sum() < len(y):
    print(f"Dropping {len(y) - valid_y_mask.sum()} rows with missing {TARGET_COLUMN}.")
    X = X[valid_y_mask]
    y = y[valid_y_mask]

X, imputer_medians = impute_median(X)

print(f"Rows (sgRNAs):  {X.shape[0]}")
