# %% CELL 4 — Load data
def stable_spearman(y_true, y_pred) -> float:
    rho, _ = spearmanr(y_true, y_pred)
    if np.isnan(rho):
        return 0.0
    return float(rho)


def impute_median(X_array):
    """Median-impute NaNs column-wise; return (X_filled, medians)."""
    medians = np.nanmedian(X_array, axis=0)
    medians = np.where(np.isnan(medians), 0.0, medians)
    if np.isnan(X_array).any():
        nan_rows, nan_cols = np.where(np.isnan(X_array))
        X_filled = X_array.copy()
        X_filled[nan_rows, nan_cols] = medians[nan_cols]
        return X_filled, medians
    return X_array, medians


print(f"Loading: {DATA_PATH}")
df = pd.read_csv(DATA_PATH, header=1, low_memory=False)

required = {"sgRNAID", TARGET_COLUMN}
missing = required - set(df.columns)
if missing:
    raise ValueError(
        f"CSV is missing columns {missing}. "
        "Matrices must include sgRNAID and cut.score."
    )

df = df.dropna(subset=["sgRNAID", TARGET_COLUMN])

y = pd.to_numeric(df[TARGET_COLUMN], errors="coerce").to_numpy(dtype=np.float64)

drop_cols = [TARGET_COLUMN]
for col in NON_FEATURE_COLUMNS:
