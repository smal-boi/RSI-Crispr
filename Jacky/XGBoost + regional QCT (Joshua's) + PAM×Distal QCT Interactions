# %% CELL 5 — Helper: leakage-safe 5-fold CV
def run_cv(
    n_features: int,
    n_estimators: int,
    verbose: bool = True,
    use_feature_selection: bool = True,
    count_engineered: bool = False,
) -> dict:
    """
    Leakage-safe CV: per-fold median impute, XGBoost selector on train fold only,
    then champion XGBoost on selected features. Matches teammate script.
    """
    n_features = min(n_features, X_raw.shape[1])
    select_features = use_feature_selection and n_features < X_raw.shape[1]

    kf = KFold(
        n_splits=N_SPLITS,
        shuffle=SHUFFLE,
        random_state=RANDOM_STATE,
    )

    r2_scores, spearman_scores, mse_scores = [], [], []
    fold_engineered_total = []
    fold_regional_qct = []
    fold_eng_extra = []

    for fold, (train_idx, val_idx) in enumerate(kf.split(X_raw), start=1):
        X_tr_raw, X_val_raw = X_raw[train_idx], X_raw[val_idx]
        y_tr, y_val = y[train_idx], y[val_idx]

        X_tr, X_val = median_impute_train_val(X_tr_raw, X_val_raw)

        if select_features:
            selector = xgb.XGBRegressor(**SELECTOR_PARAMS)
            selector.fit(X_tr, y_tr)
            top_idx = np.argsort(selector.feature_importances_)[::-1][:n_features]
            X_tr_use = X_tr[:, top_idx]
            X_val_use = X_val[:, top_idx]

            if count_engineered:
                fold_engineered_total.append(int(engineered_mask[top_idx].sum()))
                fold_regional_qct.append(
                    int((feature_family[top_idx] == "regional_qct").sum())
                )
                fold_eng_extra.append(
                    int((feature_family[top_idx] == "eng_extra").sum())
                )
        else:
            top_idx = None
            X_tr_use = X_tr
            X_val_use = X_val

        model = xgb.XGBRegressor(n_estimators=n_estimators, **CHAMPION_PARAMS)
        model.fit(X_tr_use, y_tr)
        preds = model.predict(X_val_use)

        r2 = r2_score(y_val, preds)
        rho = stable_spearman(y_val, preds)
        mse = mean_squared_error(y_val, preds)

        r2_scores.append(r2)
        spearman_scores.append(rho)
        mse_scores.append(mse)

        if verbose:
            if count_engineered and select_features:
                print(
                    f"  Fold {fold}: R^2={r2:.4f} | Spearman={rho:.4f} | "
                    f"eng={fold_engineered_total[-1]} "
                    f"(regional_qct={fold_regional_qct[-1]}, eng.*={fold_eng_extra[-1]})"
                )
            else:
                print(f"  Fold {fold}: R^2={r2:.4f} | Spearman={rho:.4f}")

    result = {
        "n_features": n_features if select_features else X_raw.shape[1],
        "n_estimators": n_estimators,
        "feature_selection": select_features,
        "mean_r2": float(np.mean(r2_scores)),
        "std_r2": float(np.std(r2_scores, ddof=0)),
        "max_r2": float(np.max(r2_scores)),
        "mean_spearman": float(np.mean(spearman_scores)),
        "mean_mse": float(np.mean(mse_scores)),
        "fold_r2": r2_scores,
    }

    if count_engineered and fold_engineered_total:
        result["mean_engineered_selected"] = float(np.mean(fold_engineered_total))
        result["mean_regional_qct_selected"] = float(np.mean(fold_regional_qct))
        result["mean_eng_extra_selected"] = float(np.mean(fold_eng_extra))
        result["fold_engineered_selected"] = fold_engineered_total
        result["fold_regional_qct_selected"] = fold_regional_qct
        result["fold_eng_extra_selected"] = fold_eng_extra

    return result


# %% CELL 6 — Final feature ranking on all data (for inspection only; not used in CV)
# CV in CELL 7 ranks inside each fold. This block shows which features the
# production selector would pick when trained on all rows.
print("Training final feature selector on all data (inspection only)...")
t0 = time.time()
final_selector = xgb.XGBRegressor(**SELECTOR_PARAMS)
final_selector.fit(X, y)

importance_df = pd.DataFrame(
    {
        "feature_idx": np.arange(X.shape[1]),
        "feature": feature_names,
        "importance_gain": final_selector.feature_importances_,
    }
).sort_values("importance_gain", ascending=False)

ranked_indices = importance_df["feature_idx"].to_numpy()

top_k = min(N_FEATURES, len(importance_df))
top_df = importance_df.head(top_k).copy()

# Label engineered features by column index (same mask as load step — avoids
# Colab string/map issues on numpy feature names).
top_idx = top_df["feature_idx"].to_numpy(dtype=int)
top_df["is_engineered"] = engineered_mask[top_idx]
top_df["family"] = feature_family[top_idx]

eng_count = int(top_df["is_engineered"].sum())
regional_qct_count = int((top_df["family"] == "regional_qct").sum())
eng_extra_count = int((top_df["family"] == "eng_extra").sum())

# Sanity check: warn if any regional_qct name slipped through unlabeled.
feat_str = top_df["feature"].astype(str).str.strip()
looks_engineered = feat_str.str.startswith("regional_qct") | feat_str.str.startswith("eng.")
mislabeled = top_df[looks_engineered & ~top_df["is_engineered"]]
if len(mislabeled) > 0:
    print("WARNING: engineered feature names with is_engineered=False:")
    print(mislabeled[["feature", "is_engineered"]].head(10).to_string(index=False))

top_df["feature_display"] = top_df.apply(
    lambda row: f"*[ENG]* {row['feature']}" if row["is_engineered"] else row["feature"],
    axis=1,
)

print(f"Ranked {len(ranked_indices)} features in {time.time() - t0:.1f}s")
print(
    f"Top {top_k} features (FULL-DATA selector — inspection only, not teammate's 83):\n"
    f"  Engineered total:     {eng_count} / {top_k}\n"
    f"    regional_qct_*:     {regional_qct_count}\n"
    f"    eng.* (extras):     {eng_extra_count}\n"
    f"  Teammate's ~83 is per-fold CV average — see CELL 7."
)
print(
    top_df[["feature_display", "importance_gain", "is_engineered"]]
    .rename(columns={"feature_display": "feature"})
    .to_string(index=False)
)


