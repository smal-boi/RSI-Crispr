def classify_qct_property(col: str) -> Optional[str]:
    lower = col.lower()
    if "hlgap" in lower:
        return "hlgap"
    if "hbond.energy" in lower:
        return "hbond_energy"
    if "hbond.stacking" in lower:
        return "hbond_stacking"
    if "no.electrons" in lower:
        return "electrons"
    return None


def parse_qct_column(col: str):
    match = re.match(r"p(\d+)([A-Za-z]+)\.", col)
    if match is None:
        return None
    position = int(match.group(1))
    molecular_unit = match.group(2).lower()
    property_class = classify_qct_property(col)
    if property_class is None:
        return None
    return position, molecular_unit, property_class


def rowwise_slope(values: np.ndarray, positions: List[int]) -> np.ndarray:
    values = np.asarray(values, dtype=np.float32)
    pos = np.asarray(positions, dtype=np.float32)

    if values.shape[1] < 2:
        return np.zeros(values.shape[0], dtype=np.float32)

    row_means = np.nanmean(values, axis=1)
    row_means = np.where(np.isnan(row_means), 0.0, row_means)
    filled = np.where(np.isnan(values), row_means[:, None], values)

    x_centered = pos - pos.mean()
    denominator = float(np.sum(x_centered ** 2))
    if denominator == 0:
        return np.zeros(values.shape[0], dtype=np.float32)

    y_centered = filled - filled.mean(axis=1, keepdims=True)
    slopes = y_centered @ x_centered / denominator
    return slopes.astype(np.float32)


def make_regional_qct_summary_features(
    X_df_numeric: pd.DataFrame,
) -> Tuple[pd.DataFrame, list]:
    """Teammate's regional QCT summary feature builder."""
    qct_column_info = []
    for col in X_df_numeric.columns:
        parsed = parse_qct_column(col)
        if parsed is None:
            continue
        position, molecular_unit, property_class = parsed
        if molecular_unit not in MOLECULAR_UNITS:
            continue
        qct_column_info.append({
            "column": col,
            "position": position,
            "molecular_unit": molecular_unit,
            "property_class": property_class,
        })

    qct_info_df = pd.DataFrame(qct_column_info)
    if qct_info_df.empty:
        raise ValueError("No QCT columns could be identified.")

    engineered_features: Dict[str, np.ndarray] = {}
    feature_definitions = []
    region_mean_cache: Dict[tuple, np.ndarray] = {}

    for molecular_unit in MOLECULAR_UNITS:
        for property_class in sorted(qct_info_df["property_class"].unique()):
            for region_name, region_positions in REGIONS.items():
                subset = qct_info_df[
                    (qct_info_df["molecular_unit"] == molecular_unit)
                    & (qct_info_df["property_class"] == property_class)
                    & (qct_info_df["position"].isin(region_positions))
                ].copy()

                if subset.shape[0] < 2:
                    continue

                subset = subset.sort_values(["position", "column"])
                cols = list(subset["column"])
                positions = list(subset["position"])
                data = X_df_numeric[cols]

                prefix = (
                    f"{REGIONAL_QCT_PREFIX}{molecular_unit}_"
                    f"{property_class}_{region_name}"
                )

                mean_feature = data.mean(axis=1, skipna=True).astype(np.float32)
                std_feature = data.std(axis=1, skipna=True).fillna(0.0).astype(np.float32)
                min_feature = data.min(axis=1, skipna=True).astype(np.float32)
                max_feature = data.max(axis=1, skipna=True).astype(np.float32)
                range_feature = (max_feature - min_feature).astype(np.float32)
                slope_feature = rowwise_slope(
                    data.to_numpy(dtype=np.float32), positions
                )

                engineered_features[f"{prefix}_mean"] = mean_feature.to_numpy()
                engineered_features[f"{prefix}_std"] = std_feature.to_numpy()
                engineered_features[f"{prefix}_min"] = min_feature.to_numpy()
                engineered_features[f"{prefix}_max"] = max_feature.to_numpy()
                engineered_features[f"{prefix}_range"] = range_feature.to_numpy()
                engineered_features[f"{prefix}_slope"] = slope_feature

                region_mean_cache[(molecular_unit, property_class, region_name)] = (
                    mean_feature.to_numpy()
                )

                feature_definitions.append({
                    "feature_prefix": prefix,
                    "molecular_unit": molecular_unit,
                    "property_class": property_class,
                    "region": region_name,
                    "source_column_count": len(cols),
                })

    # Region contrast features (teammate)
    for molecular_unit in MOLECULAR_UNITS:
        for property_class in sorted(qct_info_df["property_class"].unique()):
            pam_key = (molecular_unit, property_class, "pamprox_p16_20")
            distal_key = (molecular_unit, property_class, "distal_p1_5")
            middle_key = (molecular_unit, property_class, "middle_p6_15")

            if pam_key in region_mean_cache and distal_key in region_mean_cache:
                name = (
                    f"regional_qct_contrast_{molecular_unit}_{property_class}"
                    f"_pamprox_minus_distal_mean"
                )
                engineered_features[name] = (
                    region_mean_cache[pam_key] - region_mean_cache[distal_key]
                ).astype(np.float32)

            if pam_key in region_mean_cache and middle_key in region_mean_cache:
                name = (
                    f"regional_qct_contrast_{molecular_unit}_{property_class}"
                    f"_pamprox_minus_middle_mean"
                )
                engineered_features[name] = (
                    region_mean_cache[pam_key] - region_mean_cache[middle_key]
                ).astype(np.float32)

            if distal_key in region_mean_cache and middle_key in region_mean_cache:
                name = (
                    f"regional_qct_contrast_{molecular_unit}_{property_class}"
                    f"_distal_minus_middle_mean"
                )
                engineered_features[name] = (
                    region_mean_cache[distal_key] - region_mean_cache[middle_key]
                ).astype(np.float32)

    engineered_df = pd.DataFrame(engineered_features)
    engineered_df = engineered_df.replace([np.inf, -np.inf], np.nan)
    engineered_df = engineered_df.fillna(engineered_df.median(numeric_only=True))
    engineered_df = engineered_df.fillna(0.0)

    return engineered_df, feature_definitions


def make_pam_interaction_features(
    df: pd.DataFrame,
    regional_qct_df: pd.DataFrame,
) -> pd.DataFrame:
    """
    Optional extra family: PAM one-hot × distal regional QCT mean.
    Uses teammate's distal_p1_5 mean columns when available.
    """
    pam_present = [c for c in PAM_COLS if c in df.columns]
    if not pam_present:
        return pd.DataFrame(index=df.index)

    new_cols: Dict[str, np.ndarray] = {}
    for pam_col in pam_present:
        pam_vals = pd.to_numeric(df[pam_col], errors="coerce").fillna(0.0).to_numpy()
        for molecular_unit, property_class in PAM_INTERACTION_KEYS:
            col_name = (
                f"{REGIONAL_QCT_PREFIX}{molecular_unit}_{property_class}"
                f"_distal_p1_5_mean"
            )
            if col_name not in regional_qct_df.columns:
                continue
            seed_mean = regional_qct_df[col_name].to_numpy()
            name = (
                f"{EXTRA_PREFIX}interact.{pam_col}_x_"
                f"{molecular_unit}_{property_class}.distal_mean"
            )
            new_cols[name] = (pam_vals * seed_mean).astype(np.float32)

    return pd.DataFrame(new_cols, index=df.index)


def read_matrix_with_title(path: str) -> Tuple[Optional[str], pd.DataFrame]:
    with open(path, encoding="utf-8", errors="replace") as handle:
        first = handle.readline()
    if first.lower().startswith("suppe") or "sgRNAID" not in first:
        title = first.rstrip("\n")
        df = pd.read_csv(path, header=1, low_memory=False)
    else:
        title = None
        df = pd.read_csv(path, header=0, low_memory=False)
    return title, df


def write_matrix_with_title(path: str, title: Optional[str], df: pd.DataFrame) -> None:
    os.makedirs(os.path.dirname(path) or ".", exist_ok=True)
    with open(path, "w", encoding="utf-8", newline="") as handle:
        if title:
            handle.write(title + "\n")
    df.to_csv(path, mode="a", index=False)


