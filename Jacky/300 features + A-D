def _normalize_feature_name(name) -> str:
    return str(name).strip()


def is_engineered_feature(name) -> bool:
    """True for columns added by add_engineered_features.py."""
    s = _normalize_feature_name(name)
    return s.startswith("regional_qct") or s.startswith("eng.")


def engineered_family(name) -> str:
    s = _normalize_feature_name(name)
    if s.startswith("regional_qct"):
        return "regional_qct"
    if s.startswith("eng."):
        return "eng_extra"
    return "original"


