def stable_spearman(y_true, y_pred) -> float:
    rho, _ = spearmanr(y_true, y_pred)
    if np.isnan(rho):
        return 0.0
    return float(rho)


def impute_median(X_array):
    """Median-impute NaNs column-wise; return (X_filled, medians)."""
    medians = np.nanmedian(X_array, axis=0)
    medians = np.where(np.isnan(medians), 0.0, medians)
    if np.isnan(X_array).any():
        nan_rows, nan_cols = np.where(np.isnan(X_array))
        X_filled = X_array.copy()
        X_filled[nan_rows, nan_cols] = medians[nan_cols]
        return X_filled, medians
    return X_array, medians


def median_impute_train_val(X_train, X_val):
    """Median imputation fit on training fold only (matches teammate script)."""
    X_train = X_train.astype(np.float32, copy=True)
    X_val = X_val.astype(np.float32, copy=True)

    medians = np.nanmedian(X_train, axis=0)
    medians = np.where(np.isnan(medians), 0.0, medians)

    train_nan_rows, train_nan_cols = np.where(np.isnan(X_train))
    val_nan_rows, val_nan_cols = np.where(np.isnan(X_val))

    X_train[train_nan_rows, train_nan_cols] = medians[train_nan_cols]
    X_val[val_nan_rows, val_nan_cols] = medians[val_nan_cols]

    return X_train, X_val


