print("If Check A is closer to ~0.25 → top-k selection is doing a lot.")

# %% CELL 11 — CHECK B: fair CV (rank features inside each fold only)
# No leakage: validation rows never influence which features are kept.
# Slower than cell 7 because RF ranking runs 5 times.
print("=" * 50)
print("CHECK B: PER-FOLD FEATURE SELECTION (fair)")
print(f"n_features:   {N_FEATURES}")
print(f"n_estimators: {N_ESTIMATORS}")
print("=" * 50)

kf = KFold(n_splits=N_SPLITS, shuffle=SHUFFLE, random_state=RANDOM_STATE)
fair_r2, fair_spearman, fair_mse = [], [], []

for fold, (train_idx, val_idx) in enumerate(kf.split(X), start=1):
    X_tr, X_val = X[train_idx], X[val_idx]
    y_tr, y_val = y[train_idx], y[val_idx]

    # Rank features using TRAINING fold only
    selector_fold = RandomForestRegressor(
        n_estimators=SELECTOR_TREES,
        max_depth=SELECTOR_DEPTH,
        random_state=RANDOM_STATE,
        n_jobs=-1,
    )
    selector_fold.fit(X_tr, y_tr)
    top_idx = np.argsort(selector_fold.feature_importances_)[::-1][:N_FEATURES]

    model = xgb.XGBRegressor(n_estimators=N_ESTIMATORS, **XGB_PARAMS)
    model.fit(X_tr[:, top_idx], y_tr)
    preds = model.predict(X_val[:, top_idx])

    r2 = r2_score(y_val, preds)
    rho, _ = spearmanr(y_val, preds)
    mse = mean_squared_error(y_val, preds)

    fair_r2.append(r2)
    fair_spearman.append(rho)
    fair_mse.append(mse)
    print(f"  Fold {fold}: R^2={r2:.4f} | Spearman={rho:.4f}")

print("\n" + "=" * 50)
print("CHECK B RESULTS (fair / defensible)")
print("=" * 50)
print(f" Mean CV R^2:       {np.mean(fair_r2):.4f}")
print(f" Max fold R^2:      {np.max(fair_r2):.4f}")
print(f" Mean CV Spearman:  {np.mean(fair_spearman):.4f}")
print(f" Mean CV MSE:       {np.mean(fair_mse):.4f}")
print("=" * 50)
print("Compare to champion (leaky top-500) R^2 = 0.2931.")
print("A small drop (e.g. 0.29 → 0.27–0.28) means mild inflation.")
print("Use Check B when claiming improvement over the paper.")
