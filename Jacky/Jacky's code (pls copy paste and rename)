# %% CELL 2 — Imports and Drive mount

import os
import time

import numpy as np
import pandas as pd
import xgboost as xgb
from google.colab import drive
from scipy.stats import spearmanr
from sklearn.ensemble import RandomForestRegressor
from sklearn.metrics import mean_squared_error, r2_score
from sklearn.model_selection import KFold, train_test_split

drive.mount("/content/drive")

# %% CELL 3 — Config (edit only this cell for most experiments)
# Point this at E. coli or human — same code, different CSV.
# The CSV must have columns: sgRNAID, cut.score, then numeric features.
# First row may be a title row (we skip it with header=1).

DATA_PATH = '/content/drive/MyDrive/CRISPR_Project/human_feature_matrix.csv'
# DATA_PATH = "/content/drive/MyDrive/CRISPR_Project/human_feature_matrix.csv"  # when ready

# Champion settings (freeze these after grid search)
N_FEATURES = 400
N_ESTIMATORS = 400

# XGBoost hyperparameters (keep fixed while tuning N_FEATURES / N_ESTIMATORS)
XGB_PARAMS = dict(
    learning_rate=0.05,
    max_depth=4,
    subsample=0.8,
    colsample_bytree=0.8,
    random_state=42,
    n_jobs=-1,
)

# Cross-validation
N_SPLITS = 5
RANDOM_STATE = 42
SHUFFLE = True  # see notes: keeps folds mixed; turn off only if you have a reason

# Feature-ranking RF (used only to order columns by importance)
SELECTOR_TREES = 50
SELECTOR_DEPTH = 10

# %% CELL 4 — Load data
print(f"Loading: {DATA_PATH}")
df = pd.read_csv(DATA_PATH, header=1)

required = {"sgRNAID", "cut.score"}
missing = required - set(df.columns)
if missing:
    raise ValueError(
        f"CSV is missing columns {missing}. "
        "Human and E. coli matrices must both use sgRNAID and cut.score."
    )

df = df.dropna(subset=["sgRNAID", "cut.score"])

y = df["cut.score"].to_numpy()
X_df = (
    df.drop(columns=["sgRNAID", "cut.score"])
    .apply(pd.to_numeric, errors="coerce")
    .fillna(0.0)
)
X = X_df.to_numpy()
feature_names = X_df.columns.to_numpy()

print(f"Rows (sgRNAs):  {X.shape[0]}")
print(f"Raw features:   {X.shape[1]}")
print(f"Target column:  cut.score")
print(f"First features: {feature_names[:5].tolist()}")

# %% CELL 5 — Rank features once (Random Forest importance)
# NOTE: Ranking uses the full dataset, then CV uses those top features.
# That slightly inflates scores (leakage). Fine for internal comparison;
# for a paper, move ranking inside each fold later.
print("Ranking features with Random Forest...")
t0 = time.time()
selector = RandomForestRegressor(
    n_estimators=SELECTOR_TREES,
    max_depth=SELECTOR_DEPTH,
    random_state=RANDOM_STATE,
    n_jobs=-1,
)
selector.fit(X, y)

importance_df = pd.DataFrame(
    {
        "feature_idx": np.arange(X.shape[1]),
        "feature": feature_names,
        "importance": selector.feature_importances_,
    }
).sort_values("importance", ascending=False)

ranked_indices = importance_df["feature_idx"].to_numpy()

print(f"Ranked {len(ranked_indices)} features in {time.time() - t0:.1f}s")
print("Top 10 features:")
print(importance_df.head(10)[["feature", "importance"]].to_string(index=False))

# %% CELL 6 — Helper: 5-fold CV for one (n_features, n_estimators) pair
def run_cv(n_features: int, n_estimators: int, verbose: bool = True) -> dict:
    """Train XGBoost on top-n features; return mean CV metrics."""
    n_features = min(n_features, X.shape[1])
    idx = ranked_indices[:n_features]
    X_use = X[:, idx]

    kf = KFold(
        n_splits=N_SPLITS,
        shuffle=SHUFFLE,
        random_state=RANDOM_STATE,
    )

    r2_scores, spearman_scores, mse_scores = [], [], []

    for fold, (train_idx, val_idx) in enumerate(kf.split(X_use), start=1):
        model = xgb.XGBRegressor(n_estimators=n_estimators, **XGB_PARAMS)
        model.fit(X_use[train_idx], y[train_idx])
        preds = model.predict(X_use[val_idx])

        r2 = r2_score(y[val_idx], preds)
        rho, _ = spearmanr(y[val_idx], preds)
        mse = mean_squared_error(y[val_idx], preds)

        r2_scores.append(r2)
        spearman_scores.append(rho)
        mse_scores.append(mse)

        if verbose:
            print(f"  Fold {fold}: R^2={r2:.4f} | Spearman={rho:.4f}")

    return {
        "n_features": n_features,
        "n_estimators": n_estimators,
        "mean_r2": float(np.mean(r2_scores)),
        "max_r2": float(np.max(r2_scores)),
        "mean_spearman": float(np.mean(spearman_scores)),
        "mean_mse": float(np.mean(mse_scores)),
        "fold_r2": r2_scores,
    }

# %% CELL 7 — Champion run (your official baseline for this dataset)
print("=" * 50)
print("CHAMPION CV")
print(f"Data:         {os.path.basename(DATA_PATH)}")
print(f"n_features:   {N_FEATURES}")
print(f"n_estimators: {N_ESTIMATORS}")
print(f"shuffle:      {SHUFFLE}")
print("=" * 50)

champion = run_cv(N_FEATURES, N_ESTIMATORS, verbose=True)

print("\n" + "=" * 50)
print("CHAMPION RESULTS")
print("=" * 50)
print(f" Mean CV R^2:       {champion['mean_r2']:.4f}")
print(f" Max fold R^2:      {champion['max_r2']:.4f}")
print(f" Mean CV Spearman:  {champion['mean_spearman']:.4f}")
print(f" Mean CV MSE:       {champion['mean_mse']:.4f}")
print("=" * 50)

# %% CELL 8 — Optional: Random Forest baseline (all features, single 80/20 split)
# Use this only to compare against the paper-style RF, not as the main model.
RUN_RF_BASELINE = False  # set True to run

if RUN_RF_BASELINE:
    X_tr, X_te, y_tr, y_te = train_test_split(
        X, y, test_size=0.2, random_state=RANDOM_STATE
    )
    rf = RandomForestRegressor(
        n_estimators=1000, random_state=RANDOM_STATE, n_jobs=-1
    )
    print("Training RF baseline (1000 trees, all features)...")
    rf.fit(X_tr, y_tr)
    pred = rf.predict(X_te)
    print(f"RF R^2:       {r2_score(y_te, pred):.4f}")
    print(f"RF Spearman:  {spearmanr(y_te, pred)[0]:.4f}")

# %% CELL 9 — Optional: grid search over n_features x n_estimators
# Expensive. Run once, record best pair, then set N_FEATURES / N_ESTIMATORS
# in CELL 3 and freeze them.
RUN_GRID_SEARCH = True  # set True to run

N_FEATURES_GRID = [200, 400, 500, 600, 800, 1000]
N_ESTIMATORS_GRID = [200, 300, 400, 600, 800, 1000]

if RUN_GRID_SEARCH:
    print("Grid search: n_features x n_estimators")
    rows = []
    for nf in N_FEATURES_GRID:
        for ne in N_ESTIMATORS_GRID:
            # skip invalid if matrix is smaller than nf
            if nf > X.shape[1]:
                continue
            res = run_cv(nf, ne, verbose=False)
            rows.append(res)
            print(
                f"  nf={nf:4d} | ne={ne:4d} | "
                f"R^2={res['mean_r2']:.4f} | Spearman={res['mean_spearman']:.4f}"
            )

    results_df = pd.DataFrame(rows)
    best = results_df.loc[results_df["mean_r2"].idxmax()]

    print("\n" + "=" * 50)
    print("GRID SEARCH BEST")
    print("=" * 50)
    print(f" Best n_features:   {int(best['n_features'])}")
    print(f" Best n_estimators: {int(best['n_estimators'])}")
    print(f" Mean CV R^2:       {best['mean_r2']:.4f}")
    print(f" Mean CV Spearman:  {best['mean_spearman']:.4f}")
    print("=" * 50)

    print("\nR^2 pivot (rows=n_features, cols=n_estimators):")
    print(
        results_df.pivot(
            index="n_features", columns="n_estimators", values="mean_r2"
        ).round(4)
    )

    # Optional: save results to Drive
    out_path = "/content/drive/MyDrive/CRISPR_Project/grid_search_results1.csv"
    results_df.to_csv(out_path, index=False)
    print(f"\nSaved: {out_path}")

# %% CELL 10 — CHECK A: all features (no top-k selection)
# Compares XGBoost alone vs XGBoost + top-500 selection.
# Requires cells 2–6 already run. Uses N_ESTIMATORS from cell 3 (should be 400).
print("=" * 50)
print("CHECK A: ALL FEATURES (no top-k)")
print(f"n_features:   {X.shape[1]} (all)")
print(f"n_estimators: {N_ESTIMATORS}")
print("=" * 50)

check_a = run_cv(X.shape[1], N_ESTIMATORS, verbose=True)

print("\n" + "=" * 50)
print("CHECK A RESULTS")
print("=" * 50)
print(f" Mean CV R^2:       {check_a['mean_r2']:.4f}")
print(f" Mean CV Spearman:  {check_a['mean_spearman']:.4f}")
print("=" * 50)
print("Compare to champion top-500 R^2 = 0.2931 (or your cell 7 number).")
