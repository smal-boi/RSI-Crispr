# ============================================================
# Add gene essentiality feature (Keio / Baba et al. 2006)
#
# Source: Supplementary Table 6
#   Gene essentiality/baba paper/44320_2006_BFMSB4100050_MOESM8_ESM.xls
#
# Feature:
#   eng.gene_essential = 1 if target gene's b-number is in the Keio
#                        essential-candidate list, else 0
#
# Join key:
#   sgRNAID like "aaeAb3241_107_Cas9"  ->  b3241
#
# Usage:
#   1. Edit paths below
#   2. python add_gene_essentiality.py
#   3. In crispr_clean.py CELL 3, set DATA_PATH to the output CSV
#   4. Run cells 4-7 (same leakage-safe champion CV)
#
# Tip: first test this feature ALONE on the baseline matrix
# (not stacked with regional_qct) so your ablation is clean.
# ============================================================

import csv
import json
import os
import re
from typing import Optional, Set, Tuple

# --- CONFIG: edit paths ---
# Local defaults (Windows workspace)
INPUT_CSV = r"C:\Users\maqih\Documents\RSI cursor\ecoli_feature_matrix.csv"
KEIO_TABLE6_XLS = (
    r"C:\Users\maqih\Documents\RSI cursor\Gene essentiality\baba paper"
    r"\44320_2006_BFMSB4100050_MOESM8_ESM.xls"
)
OUTPUT_CSV = (
    r"C:\Users\maqih\Documents\RSI cursor\ecoli_feature_matrix_gene_essential.csv"
)

# Colab examples (uncomment and comment local paths above if needed):
# INPUT_CSV = "/content/drive/MyDrive/CRISPR_Project/ecoli_feature_matrix.csv"
