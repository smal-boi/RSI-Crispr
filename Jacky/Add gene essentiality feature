# OUTPUT_CSV = "/content/drive/MyDrive/CRISPR_Project/ecoli_feature_matrix_gene_essential.csv"

ID_COL = "sgRNAID"
TARGET_COL = "cut.score"
FEATURE_NAME = "eng.gene_essential"

# Match: geneName + bNNNN + _rest
SGRNA_B_NUMBER_RE = re.compile(r"([bB]\d+)_")


def parse_b_number_from_sgrna_id(sgrna_id: str) -> Optional[str]:
    """Extract Blattner b-number from sgRNAID, e.g. aaeAb3241_107_Cas9 -> b3241."""
    match = SGRNA_B_NUMBER_RE.search(str(sgrna_id))
    if match is None:
        return None
    return match.group(1).lower()


def load_keio_essential_b_numbers(xls_path: str) -> Set[str]:
    """
    Read Baba 2006 Supplementary Table 6 (essential gene candidates).
    Returns lower-case b-numbers like {'b0025', 'b0027', ...}.
    """
    try:
        import xlrd
    except ImportError:
        raise ImportError(
            "xlrd is required to read the Keio .xls file.\n"
            "Install with: pip install 'xlrd==1.2.0'"
        )

    if not os.path.exists(xls_path):
        raise FileNotFoundError(f"Keio Table 6 not found: {xls_path}")

    book = xlrd.open_workbook(xls_path)
    sheet = book.sheet_by_index(0)

    # Layout from inspection:
    # row 0: title
    # rows 1-3: multi-line headers
    # row 3 has 'b number' in column 6
    # data starts at row 4
    # columns: 0=ECK, 1=gene, 2=JW, ..., 6=b number
    b_col = None
    header_row = None
    for r in range(min(6, sheet.nrows)):
        for c in range(sheet.ncols):
            val = str(sheet.cell_value(r, c)).strip().lower()
            if val in ("b number", "b_number", "bnumber"):
                b_col = c
                header_row = r
                break
        if b_col is not None:
            break

    if b_col is None:
        # Fallback to the known layout
        b_col = 6
        header_row = 3

    essential: Set[str] = set()
    for r in range(header_row + 1, sheet.nrows):
        raw = str(sheet.cell_value(r, b_col)).strip()
        if not raw or raw.lower() in ("none", "nan"):
            continue
        # Accept b0025 or 0025
        raw_l = raw.lower()
        if re.fullmatch(r"b\d+", raw_l):
            essential.add(raw_l)
        elif re.fullmatch(r"\d+", raw_l):
            essential.add("b" + raw_l)

    if len(essential) < 50:
        raise ValueError(
            f"Too few essential b-numbers parsed ({len(essential)}). "
            "Check that KEIO_TABLE6_XLS points to Supplementary Table 6."
        )

    return essential


def read_matrix_with_title(path: str) -> Tuple[Optional[str], list, list]:
    """
    Returns (optional_title_row, header_list, data_rows_as_dicts_not_used).
    Actually returns title, fieldnames, list of row dicts.
    """
    with open(path, encoding="utf-8", errors="replace", newline="") as handle:
        first = handle.readline()
        if first.lower().startswith("suppe") or ID_COL not in first:
            title = first.rstrip("\n")
            reader = csv.DictReader(handle)
        else:
            title = None
            handle.seek(0)
            reader = csv.DictReader(handle)

        fieldnames = list(reader.fieldnames or [])
        rows = list(reader)

    if ID_COL not in fieldnames:
        raise ValueError(f"Missing {ID_COL} in {path}")
    if TARGET_COL not in fieldnames:
        raise ValueError(f"Missing {TARGET_COL} in {path}")

    return title, fieldnames, rows


def write_matrix_with_title(
    path: str,
    title: Optional[str],
    fieldnames: list,
    rows: list,
) -> None:
    os.makedirs(os.path.dirname(path) or ".", exist_ok=True)
    with open(path, "w", encoding="utf-8", newline="") as handle:
        if title:
            handle.write(title + "\n")
        writer = csv.DictWriter(handle, fieldnames=fieldnames, extrasaction="ignore")
        writer.writeheader()
        writer.writerows(rows)


def main() -> None:
    print("=" * 70)
    print("ADD GENE ESSENTIALITY FEATURE (Keio / Baba 2006 Table 6)")
    print("=" * 70)
    print(f"Input matrix:  {INPUT_CSV}")
    print(f"Keio Table 6:  {KEIO_TABLE6_XLS}")
    print(f"Output matrix: {OUTPUT_CSV}")

    essential_b = load_keio_essential_b_numbers(KEIO_TABLE6_XLS)
    print(f"\nKeio essential candidates loaded: {len(essential_b)}")
    print(f"Examples: {sorted(essential_b)[:8]}")

    title, fieldnames, rows = read_matrix_with_title(INPUT_CSV)
    print(f"Loaded guides: {len(rows)}")

    if FEATURE_NAME in fieldnames:
        print(f"WARNING: {FEATURE_NAME} already present — overwriting values.")
    else:
        # Insert engineered column after cut.score if possible
        if TARGET_COL in fieldnames:
            insert_at = fieldnames.index(TARGET_COL) + 1
            fieldnames = fieldnames[:insert_at] + [FEATURE_NAME] + fieldnames[insert_at:]
        else:
            fieldnames = fieldnames + [FEATURE_NAME]

    n_essential = 0
    n_nonessential = 0
    n_unparsed = 0
    unmatched_examples = []

    for row in rows:
        bnum = parse_b_number_from_sgrna_id(row[ID_COL])
        if bnum is None:
            row[FEATURE_NAME] = "0"
            n_unparsed += 1
            if len(unmatched_examples) < 5:
                unmatched_examples.append(row[ID_COL])
            continue

        is_ess = 1 if bnum in essential_b else 0
        row[FEATURE_NAME] = str(is_ess)
        if is_ess:
            n_essential += 1
        else:
            n_nonessential += 1

    write_matrix_with_title(OUTPUT_CSV, title, fieldnames, rows)

    unique_b = set()
    unique_ess_b = set()
    for row in rows:
        bnum = parse_b_number_from_sgrna_id(row[ID_COL])
        if bnum is None:
            continue
        unique_b.add(bnum)
        if bnum in essential_b:
            unique_ess_b.add(bnum)

    meta = {
        "feature": FEATURE_NAME,
        "source": "Baba et al. 2006 Keio collection, Supplementary Table 6",
        "source_file": KEIO_TABLE6_XLS,
        "definition": (
            "1 if sgRNA target gene b-number is in Keio essential-candidate list; "
            "else 0"
        ),
        "n_keio_essential_genes": len(essential_b),
        "n_guides": len(rows),
        "n_guides_essential": n_essential,
        "n_guides_nonessential": n_nonessential,
        "n_guides_unparsed_id": n_unparsed,
        "n_unique_genes_in_matrix": len(unique_b),
        "n_unique_essential_genes_in_matrix": len(unique_ess_b),
        "fraction_guides_essential": (
            float(n_essential) / len(rows) if rows else 0.0
        ),
    }

    meta_path = os.path.splitext(OUTPUT_CSV)[0] + "_essentiality_meta.json"
    with open(meta_path, "w", encoding="utf-8") as handle:
        json.dump(meta, handle, indent=2)

    print("\nFeature assignment:")
    print(f"  eng.gene_essential = 1: {n_essential} guides")
    print(f"  eng.gene_essential = 0: {n_nonessential} guides")
    print(f"  unparsed sgRNAID:       {n_unparsed}")
    print(f"  unique genes in matrix: {len(unique_b)}")
    print(f"  of which essential:     {len(unique_ess_b)}")
    if unmatched_examples:
        print(f"  unparsed examples: {unmatched_examples}")

    print(f"\nSaved: {OUTPUT_CSV}")
    print(f"Meta:  {meta_path}")
    print("\nNext steps:")
    print("  1. In crispr_clean.py CELL 3 set:")
    print(f'       DATA_PATH = r"{OUTPUT_CSV}"')
    print("     (or the Colab Drive path to that file)")
    print("  2. Re-run Cells 4 -> 6 -> 7")
    print("  3. Compare Cell 7 R^2 / Spearman to baseline (~0.2923)")
    print("  4. Check whether eng.gene_essential appears in top 300 / per fold")
    print("=" * 70)


if __name__ == "__main__":
    main()
